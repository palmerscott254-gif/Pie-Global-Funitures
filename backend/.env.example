# Minimal environment template (local + Render)

# Django
DJANGO_SECRET_KEY=replace-with-a-strong-random-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# Database
# Production/Render (recommended): set a full external PostgreSQL URL
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Local fallback:
# - If DATABASE_URL is empty and DJANGO_DEBUG=True, Django uses SQLite (backend/db.sqlite3)
# - Optional local PostgreSQL vars (used only if DATABASE_URL is empty)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# CORS / CSRF (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional S3
USE_S3=False
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Optional email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
