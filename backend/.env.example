# Minimal environment template for local dev + Render deploy

# Django
DJANGO_SECRET_KEY=replace-with-a-strong-random-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# Database
# Local: use ONE of these approaches:
# 1) DATABASE_URL=postgresql://postgres:your-password@localhost:5432/pie_global_db
# 2) POSTGRES_* variables below
POSTGRES_DB=pie_global_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-local-db-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Render: do not set DATABASE_URL manually (Render injects it when a DB is attached)

# CORS / CSRF (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional S3
USE_S3=False
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Optional email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
